<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/principal"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="32dp"
    android:background="@color/azul_escuro"
    tools:context=".MainActivity">

    <ImageButton
        android:id="@+id/botao_voltar_fluxo"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_arrow_back"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/branco"
        tools:visibility="visible" />

    <ImageView
        android:id="@+id/iv_logo_app"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_marginTop="16dp"
        app:srcCompat="@drawable/logo_hora_certa2"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_slogan"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="@string/slogan"
        android:textSize="18sp"
        android:fontFamily="sans-serif-medium"
        android:textColor="@color/branco"
        android:alpha="0.9"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/iv_logo_app" />

    <!-- Container do Consentimento -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_consentimento"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="visible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_slogan">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/scroll_consentimento"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/fundo_card_branco"
            android:padding="16dp"
            app:layout_constraintBottom_toTopOf="@+id/tv_link_termos"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_titulo_consentimento"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:fontFamily="sans-serif-bold"
                    android:text="@string/titulo_consentimento"
                    android:textAlignment="center"
                    android:textColor="@color/azul_logo"
                    android:textSize="20sp" />

                <TextView
                    android:id="@+id/tv_texto_consentimento"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif"
                    android:lineSpacingExtra="4dp"
                    android:text="@string/texto_consentimento"
                    android:textColor="@color/preto"
                    android:textSize="14sp" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <TextView
            android:id="@+id/tv_link_termos"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="@string/link_termos"
            android:textColor="@color/branco"
            android:textSize="14sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true"
            android:padding="4dp"
            app:layout_constraintBottom_toTopOf="@+id/cb_concordo"
            app:layout_constraintStart_toStartOf="parent" />

        <CheckBox
            android:id="@+id/cb_concordo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="@string/check_concordo"
            android:textColor="@color/branco"
            android:buttonTint="@color/branco"
            app:layout_constraintBottom_toTopOf="@+id/botao_concordar"
            app:layout_constraintStart_toStartOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/botao_concordar"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginBottom="16dp"
            android:text="@string/botao_concordar"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:enabled="false"
            app:cornerRadius="12dp"
            android:backgroundTint="@color/laranja_logo"
            android:textColor="@color/branco"
            app:strokeColor="@color/branco"
            app:strokeWidth="2dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Container dos Termos Detalhados -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_termos_detalhados"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_slogan">

        <androidx.core.widget.NestedScrollView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/fundo_card_branco"
            android:padding="16dp"
            app:layout_constraintBottom_toTopOf="@+id/botao_voltar_termos"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:fontFamily="sans-serif-bold"
                    android:text="@string/titulo_termos_detalhados"
                    android:textAlignment="center"
                    android:textColor="@color/azul_logo"
                    android:textSize="20sp" />

                <TextView
                    android:id="@+id/tv_texto_termos_completo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/texto_termos_completo"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif"
                    android:textColor="@color/preto"
                    android:lineSpacingExtra="4dp" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/botao_voltar_termos"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginBottom="16dp"
            android:text="@string/botao_voltar"
            android:textColor="@color/branco"
            app:strokeColor="@color/branco"
            app:strokeWidth="2dp"
            app:cornerRadius="12dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Container do Apelido -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_apelido"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_slogan">

        <TextView
            android:id="@+id/tv_titulo_apelido"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="64dp"
            android:text="@string/titulo_apelido"
            android:textSize="24sp"
            android:fontFamily="sans-serif-bold"
            android:textColor="@color/branco"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_descricao_apelido"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="@string/descricao_apelido"
            android:textSize="16sp"
            android:textColor="@color/branco"
            android:alpha="0.8"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_titulo_apelido" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/campo_apelido_layout"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:layout_marginHorizontal="8dp"
            app:boxBackgroundColor="@color/branco"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusTopStart="12dp"
            app:boxStrokeColor="@color/branco"
            app:boxStrokeWidth="2dp"
            app:hintEnabled="false"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_descricao_apelido">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_apelido"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_apelido"
                android:inputType="textPersonName"
                android:textColor="@color/preto"
                android:padding="16dp" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/botao_proximo_apelido"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginBottom="24dp"
            android:layout_marginHorizontal="8dp"
            android:text="@string/botao_proximo"
            android:textAllCaps="false"
            android:textSize="16sp"
            app:cornerRadius="12dp"
            android:backgroundTint="@color/laranja_logo"
            android:textColor="@color/branco"
            app:strokeColor="@color/branco"
            app:strokeWidth="2dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Container do Perfil (Novo) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_perfil"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_slogan">

        <TextView
            android:id="@+id/tv_saudacao_perfil"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:gravity="center"
            android:text="@string/saudacao_perfil"
            android:textSize="24sp"
            android:fontFamily="sans-serif-bold"
            android:textColor="@color/branco"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_descricao_perfil"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="@string/descricao_perfil"
            android:textSize="16sp"
            android:textColor="@color/branco"
            android:alpha="0.8"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_saudacao_perfil" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layout_selecao_sexo"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:layout_marginHorizontal="8dp"
            android:hint="@string/label_sexo"
            app:boxBackgroundColor="@color/branco"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusTopStart="12dp"
            app:boxStrokeColor="@color/branco"
            app:boxStrokeWidth="2dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_descricao_perfil">

            <AutoCompleteTextView
                android:id="@+id/auto_sexo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:padding="16dp"
                android:textColor="@color/preto" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:id="@+id/tv_label_ano"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginStart="8dp"
            android:text="@string/label_ano_nascimento"
            android:textColor="@color/branco"
            android:textSize="16sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layout_selecao_sexo" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/botao_escolher_ano"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginTop="8dp"
            android:layout_marginHorizontal="8dp"
            android:text="@string/botao_selecionar_ano"
            android:textColor="@color/branco"
            app:strokeColor="@color/branco"
            app:strokeWidth="2dp"
            app:cornerRadius="12dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_label_ano" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/botao_proximo_perfil"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginBottom="24dp"
            android:layout_marginHorizontal="8dp"
            android:text="@string/botao_proximo"
            android:textAllCaps="false"
            android:textSize="16sp"
            app:cornerRadius="12dp"
            android:backgroundTint="@color/laranja_logo"
            android:textColor="@color/branco"
            app:strokeColor="@color/branco"
            app:strokeWidth="2dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Container de Boas-vindas -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_boas_vindas"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_slogan">

        <TextView
            android:id="@+id/tv_titulo_boas_vindas"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="64dp"
            android:gravity="center"
            android:text="@string/titulo_boas_vindas"
            android:textSize="28sp"
            android:fontFamily="sans-serif-black"
            android:textColor="@color/branco"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_descricao_boas_vindas"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="@string/descricao_boas_vindas"
            android:textSize="18sp"
            android:textColor="@color/branco"
            android:alpha="0.9"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_titulo_boas_vindas" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/botao_comecar"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginBottom="24dp"
            android:layout_marginHorizontal="8dp"
            android:text="@string/botao_comecar"
            android:textAllCaps="false"
            android:textSize="18sp"
            app:cornerRadius="12dp"
            android:backgroundTint="@color/laranja_logo"
            android:textColor="@color/branco"
            app:strokeColor="@color/branco"
            app:strokeWidth="2dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
